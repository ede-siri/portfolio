# Spotify Web API (server-side only)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Must match Spotify Dashboard exactly (no trailing slash, no localhost)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# Optional: used to build the callback URL in production
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Setup steps:
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Add this redirect URI in the app settings:
#    http://127.0.0.1:3001/api/spotify/callback
# 3. Copy Client ID and Client Secret into .env.local
# 4. Visit http://127.0.0.1:3001/api/spotify/login to generate a refresh token
#    (re-run if scopes change — top tracks/artists need user-top-read)
# 5. Add the returned SPOTIFY_REFRESH_TOKEN to .env.local
# 6. Restart the dev server
